# Copy to .env and fill in when wiring a backend. Vite only exposes VITE_* vars
# to the client. The real .env is gitignored; never commit it.

# Backend toggle: 'supabase' activates Supabase auth + sync; any other value
# (or leaving it empty) runs the app fully local (localStorage only).
VITE_BACKEND=

# Supabase (auth + data): project URL + publishable/anon key, Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
